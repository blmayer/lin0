diff --git a/Makefile b/Makefile
index 5ea21183..7410c45b 100644
--- a/Makefile
+++ b/Makefile
@@ -279,7 +279,7 @@ endif
 
 # convert "include/tccdefs.h" to "tccdefs_.h"
 %_.h : include/%.h conftest.c
-	$S$(CC) -DC2STR $(filter %.c,$^) -o c2str.exe && ./c2str.exe $< $@
+	$S$(CC) -DC2STR $(filter %.c,$^) -o c2str.exe && $$outdir/lib/libc.so ./c2str.exe $< $@
 
 # target specific object rule
 $(X)%.o : %.c $(LIBTCC_INC)
diff --git a/lib/Makefile b/lib/Makefile
index 4727beeb..060eb346 100644
--- a/lib/Makefile
+++ b/lib/Makefile
@@ -11,12 +11,12 @@ XCFG = $(or $(findstring -win,$T),-unx)
